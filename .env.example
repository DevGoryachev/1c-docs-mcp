MCP_DB_PATH=data/sqlite/docs.db
MCP_DATA_DIR=data/normalized
MCP_DEFAULT_SEARCH_LIMIT=10
MCP_MAX_SEARCH_LIMIT=50
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=3000
MCP_HTTP_ENDPOINT=/mcp
MCP_HTTP_AUTH_ENABLED=false
MCP_HTTP_BEARER_TOKEN=
MCP_PUBLIC_BASE_URL=
MCP_HTTP_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1
MCP_HTTP_MAX_BODY_BYTES=1048576
MCP_HTTP_REQUEST_TIMEOUT_MS=15000

# Shared mode template (replace placeholders with real values):
# MCP_HTTP_HOST=0.0.0.0
# MCP_HTTP_AUTH_ENABLED=true
# MCP_HTTP_BEARER_TOKEN=<YOUR_STRONG_TOKEN>
# MCP_PUBLIC_BASE_URL=http://<YOUR_HOST_OR_IP>:3000
